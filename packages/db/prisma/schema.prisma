generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// User authentication
model User {
  id        String   @id @default(cuid())
  username  String   @unique
  password  String   // bcrypt hash
  orgId     String   @default("default")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Organization workspace settings
model Subscription {
  id        String   @id @default(cuid())
  orgId     String   @unique

  // Onboarding
  onboardingCompleted Boolean @default(false)

  // Google Calendar integration (workspace-level)
  googleAccessToken   String?
  googleRefreshToken  String?
  googleTokenExpiry   DateTime?
  googleEmail         String?   // Google account email for display

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Voice agent configuration
model Agent {
  id       String  @id @default(cuid())
  orgId    String
  name     String
  username String? @unique // URL-safe slug for call app link, e.g. "joes-barbershop"

  // Agent config
  instruction    String @default("")
  greeting       String @default("Hello! How can I help you with your reservation today?")
  voice          String @default("Puck") // Gemini voice preset
  model          String @default("gemini-live-2.5-flash-native-audio")
  language       String @default("en-US")

  // Phone number (provisioned)
  phoneNumber String?

  // Google Calendar integration
  calendarId            String?
  calendarAccessToken   String?
  calendarRefreshToken  String?
  calendarTokenExpiry   DateTime?

  // Business info for the agent
  businessName    String @default("")
  businessType    String @default("restaurant") // restaurant, salon, clinic, etc.
  timezone        String @default("America/New_York")
  operatingHours  Json?  // { mon: { open: "09:00", close: "17:00" }, ... }
  bookingDuration Int    @default(60) // default slot duration in minutes
  maxAdvanceDays  Int    @default(30) // how far ahead to allow booking

  // Resource capacity
  capacityType  String @default("slots") // "tables", "rooms", "chairs", "courts", "slots", "units", "bays"
  capacityCount Int    @default(0)       // total number of resources

  // Widget customization
  widgetColor    String @default("#0a0a0a")
  widgetBgColor  String @default("#0a0a0a")
  widgetPosition String @default("bottom-right") // "bottom-right" | "bottom-left"

  status AgentStatus @default(ACTIVE)

  // Relations
  conversations Conversation[]
  callLogs      CallLog[]
  resources     Resource[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([orgId])
}

enum AgentStatus {
  ACTIVE
  PAUSED
  PROVISIONING
  FAILED
}

// A phone call / voice session
model Conversation {
  id      String @id @default(cuid())
  agentId String
  agent   Agent  @relation(fields: [agentId], references: [id], onDelete: Cascade)

  // Caller info
  callerPhone String?
  callerName  String?
  callerEmail String?

  // Session
  sessionId String @unique
  status    ConversationStatus @default(IN_PROGRESS)

  // Outcome
  bookingMade   Boolean  @default(false)
  bookingStart  DateTime?
  bookingEnd    DateTime?
  calendarEventId String?
  summary       String?

  // Transcript
  messages Message[]

  startedAt   DateTime  @default(now())
  endedAt     DateTime?

  @@index([agentId])
  @@index([status])
}

enum ConversationStatus {
  IN_PROGRESS
  COMPLETED
  MISSED
  FAILED
}

// Individual message in a conversation
model Message {
  id             String @id @default(cuid())
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  role    MessageRole
  content String
  // Audio transcript metadata
  audioUrl String?

  createdAt DateTime @default(now())

  @@index([conversationId, createdAt])
}

enum MessageRole {
  USER
  ASSISTANT
  SYSTEM
  TOOL
}

// Call log for analytics
model CallLog {
  id      String @id @default(cuid())
  agentId String
  agent   Agent  @relation(fields: [agentId], references: [id], onDelete: Cascade)

  callerPhone   String?
  durationSecs  Int      @default(0)
  outcome       CallOutcome
  bookingMade   Boolean  @default(false)

  startedAt DateTime @default(now())

  @@index([agentId, startedAt])
}

enum CallOutcome {
  BOOKING_CREATED
  BOOKING_RESCHEDULED
  BOOKING_CANCELED
  INQUIRY_ONLY
  MISSED
  FAILED
}

// Bookable resource (table, room, chair, etc.)
model Resource {
  id      String @id @default(cuid())
  agentId String
  agent   Agent  @relation(fields: [agentId], references: [id], onDelete: Cascade)

  name     String         // "Table 1", "Room A", "Chair 3"
  type     String         // "table", "room", "chair", "court", "slot", "unit", "bay"
  capacity Int            @default(1) // e.g., 4 seats per table
  status   ResourceStatus @default(ACTIVE)

  createdAt DateTime @default(now())

  @@index([agentId])
}

enum ResourceStatus {
  ACTIVE
  INACTIVE
}

