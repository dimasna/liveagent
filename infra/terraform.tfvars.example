project_id            = "my-gcp-project"
region                = "us-central1"
environment           = "production"

# Custom domain (optional — leave empty to use Cloud Run default URLs)
# Requires domain verification: https://www.google.com/webmasters/verification/home
# Creates: {domain} (web), agent.{domain}, widget.{domain}
domain                = ""                          # e.g. "liveagent.dev"

# App secrets
session_secret        = "a-random-secret-key-at-least-32-chars-long"
auth_username         = "admin"
auth_password         = "changeme"
google_client_id      = "...apps.googleusercontent.com"
google_client_secret  = "GOCSPX-..."
demo_agent_id         = ""                          # set after creating your first agent
google_api_key        = "AIza..."
google_places_api_key = "AIza..."
