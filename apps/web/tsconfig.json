{
  "extends": "@liveagent/typescript-config/nextjs.json",
  "compilerOptions": {
    "paths": {
      "@/*": [
        "./app/*"
      ],
      "@modules/*": [
        "./modules/*"
      ],
      "@lib/*": [
        "./lib/*"
      ]
    },
    "allowJs": true
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts"
  ],
  "exclude": [
    "node_modules"
  ]
}
